    <!-- JavaScript Core Application Logic -->
    <script>
        // Embedded API Key for seamless organizational access
        const embeddedApiKey = 'AQ.Ab8RN6KDFTENaipRd1CVLie8B2P_8coeHmP-0T2iXUHfyyW04Q';

        // Initialize App
        window.addEventListener('DOMContentLoaded', () => {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('mon-date').value = today;
            document.getElementById('mtg-date').value = today;

            // Render default FAX preview
            updateFaxPreview();
