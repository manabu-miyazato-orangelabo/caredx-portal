        function fillFaxSample(type) {
            if (type === 1) {
                document.getElementById('fax-to-company').value = 'デイサービスあおぞら';
                document.getElementById('fax-to-dept').value = '相談室';
                document.getElementById('fax-to-name').value = '佐藤 花子';
                document.getElementById('fax-subject').value = 'サービス担当者会議のご案内および照会書送付';
                document.getElementById('fax-message').value = `拝啓\n\n平素より大変お世話になっております。ORANGE LABOです。\n\n更新に伴い、サービス担当者会議のご案内ならびにケアプラン原案を送付いたします。\n別紙「照会書」にご意見をご記入の上、ご返信くださいますようお願い申し上げます。`;
