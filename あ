    <style>
        /* Custom UI styles for print, glassmorphism & cards */
        body {
            font-family: 'Noto Sans JP', 'Inter', sans-serif;
            background-color: #F8FAFC;
            color: #0F172A;
            -webkit-font-smoothing: antialiased;
        }

        /* Glassmorphism subtle overlay */
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        /* A4 aspect ratio preview canvas */
        .a4-paper {
            width: 210mm;
            min-height: 297mm;
            padding: 16mm;
            margin: 0 auto;
            background: white;
            box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.1), 0 8px 10px -6px rgba(15, 23, 42, 0.05);
            box-sizing: border-box;
            position: relative;
            color: #0D0C0C;
        }

        @media (max-width: 850px) {
            .a4-paper {
                width: 100%;
                min-height: auto;
                padding: 12px;
            }
        }

        /* Print Container */
        @media print {
            body { background: white !important; padding: 0 !important; margin: 0 !important; }
            .no-print { display: none !important; }
            .a4-paper { box-shadow: none !important; border: none !important; padding: 0 !important; width: 100% !important; }
            @page { size: A4 portrait; margin: 10mm 12mm; }
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #F1F5F9; }
        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 999px; }
        ::-webkit-scrollbar-thumb:hover { background: #94A3B8; }

        /* Pulse Animations for Microphones */
        @keyframes pulse-red {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
            50% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        }
        .recording-pulse { animation: pulse-red 1.5s infinite; }
    </style>
</head>
