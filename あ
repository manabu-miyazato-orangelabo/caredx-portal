        // Tab Navigation Switcher
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-orange', 'text-white', 'shadow');
                btn.classList.add('text-slate-300', 'hover:text-white', 'hover:bg-navy-light');
            });

            document.getElementById(tabId).classList.remove('hidden');
            const activeNav = document.getElementById('nav-' + tabId);
            if (activeNav) {
                activeNav.classList.add('bg-orange', 'text-white', 'shadow');
                activeNav.classList.remove('text-slate-300', 'hover:text-white', 'hover:bg-navy-light');
            }
        }

        function openToolTab(tabId) {
            switchTab(tabId);
            document.getElementById('workspace').scrollIntoView({ behavior: 'smooth' });
        }

        function scrollToSection(id) {
            const el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth' });
        }

        // File Handler Helper
        let currentAudioBase64 = null;
        let currentAudioMime = null;

        function handleAudioSelect(input, targetSpanId) {
            const file = input.files[0];
            const span = document.getElementById(targetSpanId);
            if (!file) {
                span.textContent = '';
                currentAudioBase64 = null;
                return;
            }
            span.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(1)}MB)`;
            currentAudioMime = file.type || 'audio/mp3';

            const reader = new FileReader();
            reader.onload = () => {
                currentAudioBase64 = reader.result.split(',')[1];
            };
            reader.readAsDataURL(file);
        }

        // Gemini AI Call Function
        async function callGemini(systemPrompt, userText, audioBase64 = null, audioMime = null) {
            const models = ['gemini-2.5-flash-lite', 'gemini-3.1-flash-lite', 'gemini-2.5-flash'];
            const userParts = [{ text: userText }];

            if (audioBase64) {
                userParts.push({
                    inline_data: { mime_type: audioMime || 'audio/mp3', data: audioBase64 }
                });
            }

            const payload = {
                systemInstruction: { parts: [{ text: systemPrompt }] },
                contents: [{ role: 'user', parts: userParts }],
                generationConfig: {
                    temperature: 0.3,
                    responseMimeType: 'application/json'
                }
            };

            for (const model of models) {
                try {
                    const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${embeddedApiKey}`;
                    const res = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (res.ok) {
                        const data = await res.json();
                        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
                        if (text) return JSON.parse(text);
                    }
                } catch (e) {
                    console.warn(`Model ${model} fallback...`, e);
                }
            }
            throw new Error('Gemini AIの呼び出しに失敗しました。時間をおいて再試行してください。');
        }

        // Generate Monitoring AI
        async function generateMonitoring() {
            const goals = document.getElementById('mon-goals').value.trim();
            const notes = document.getElementById('mon-notes').value.trim();
            const btn = document.getElementById('btn-mon-generate');

            if (!goals && !notes && !currentAudioBase64) {
                showToast('目標または聞き取り内容を入力してください', 'info');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> <span>AI作成中...</span>`;

            const sysPrompt = `あなたは介護ソフト「カイポケ」に貼り付けるモニタリング記録を作成する居宅介護支援専門員のアシスタントです。
JSON形式で出力してください：
{"goals":[{"goal":"短期目標","evaluation":"支援上の要点（100字以内）"}],"summary":"総合評価（改行最小限）"}`;

            const userPrompt = `【短期目標】\n${goals}\n\n【聞き取り内容】\n${notes}`;

            try {
                const res = await callGemini(sysPrompt, userPrompt, currentAudioBase64, currentAudioMime);
                
                const goalsContainer = document.getElementById('mon-goals-output');
                goalsContainer.innerHTML = '';

                (res.goals || []).forEach((g, idx) => {
                    const div = document.createElement('div');
                    div.className = 'bg-slate-50 p-3 rounded-xl border border-slate-200 space-y-1';
                    div.innerHTML = `
                        <label class="block text-xs font-bold text-navy-dark">短期目標${idx + 1}：${g.goal}</label>
                        <textarea class="w-full p-2 text-sm border border-slate-300 rounded focus:outline-none">${g.evaluation}</textarea>
                    `;
                    goalsContainer.appendChild(div);
                });

                document.getElementById('mon-summary-output').value = res.summary || '';
                document.getElementById('mon-result').classList.remove('hidden');
                showToast('モニタリング記録を作成しました！');
            } catch (err) {
                showToast(err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="fa-solid fa-wand-magic-sparkles"></i> <span>AIでモニタリング記録を作成する</span>`;
            }
        }

        // Generate Meeting AI
        async function generateMeeting() {
            const transcript = document.getElementById('mtg-transcript').value.trim();
            const btn = document.getElementById('btn-mtg-generate');

            if (!transcript && !currentAudioBase64) {
                showToast('文字起こしまたは音声ファイルを準備してください', 'info');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> <span>AI作成中...</span>`;

            const sysPrompt = `あなたは優秀なケアマネジャーとしてサービス担当者会議録を作成します。
JSON形式で回答してください：
{"items":"検討した項目","discussion":"検討内容","conclusion":"結論","issues":"残された課題"}`;

            try {
                const res = await callGemini(sysPrompt, transcript, currentAudioBase64, currentAudioMime);
                document.getElementById('mtg-items-out').value = res.items || '';
                document.getElementById('mtg-disc-out').value = res.discussion || '';
                document.getElementById('mtg-conc-out').value = res.conclusion || '';
                document.getElementById('mtg-iss-out').value = res.issues || '';

                document.getElementById('mtg-result').classList.remove('hidden');
                showToast('会議録を作成しました！');
            } catch (err) {
                showToast(err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="fa-solid fa-users"></i> <span>AIで会議録を作成する</span>`;
            }
        }

        // Plan Extract AI
        async function extractPlan() {
            const text = document.getElementById('plan-input').value.trim();
            if (!text) return;

            const sysPrompt = `第2表テキストから短期目標・サービス・頻度を箇条書きで抽出してください。JSON形式：{"summary":"抽出結果"}`;
            try {
                const res = await callGemini(sysPrompt, text);
                document.getElementById('plan-output').value = res.summary || '';
                document.getElementById('plan-result').classList.remove('hidden');
                showToast('要約抽出が完了しました');
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        // FAX Preview Renderer
