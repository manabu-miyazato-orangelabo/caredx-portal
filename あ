        // Print Fax Function
        function triggerPrintFax() {
            const content = document.getElementById('fax-paper-preview').innerHTML;
            const printWin = window.open('', '_blank');
            if (!printWin) {
                showToast('ポップアップがブロックされました', 'error');
                return;
            }

            printWin.document.write(`
                <!DOCTYPE html>
                <html>
                <head>
                    <title>FAX送付状印刷</title>
                    <script src="https://cdn.tailwindcss.com"><\/script>
                    <style>
                        body { padding: 12mm 15mm; background: white; font-family: 'Noto Sans JP', sans-serif; }
                        @page { size: A4 portrait; margin: 0; }
                    </style>
                </head>
                <body>
                    ${content}
                    <script>
                        window.onload = function() { setTimeout(() => window.print(), 500); }
                    <\/script>
                </body>
                </html>
            `);
            printWin.document.close();
        }

        // Copy Helpers
        function copyAllMonitoring() {
            const name = document.getElementById('mon-user-name').value || '未入力';
            const date = document.getElementById('mon-date').value || '未入力';
            let txt = `【モニタリング記録】\n利用者名：${name}\n記録日：${date}\n\n■短期目標ごとの要点\n`;

            document.querySelectorAll('#mon-goals-output div').forEach(el => {
                txt += `${el.querySelector('label').textContent}\n${el.querySelector('textarea').value}\n\n`;
            });

            txt += `■総合評価\n${document.getElementById('mon-summary-output').value}`;
            copyText(txt);
        }

        function copyAllMeeting() {
            const name = document.getElementById('mtg-user-name').value || '未入力';
            const date = document.getElementById('mtg-date').value || '未入力';
            let txt = `【サービス担当者会議録】\n利用者名：${name}\n会議日：${date}\n\n`;
            txt += `■検討した項目\n${document.getElementById('mtg-items-out').value}\n\n`;
            txt += `■検討内容\n${document.getElementById('mtg-disc-out').value}\n\n`;
            txt += `■結論\n${document.getElementById('mtg-conc-out').value}\n\n`;
            txt += `■残された課題\n${document.getElementById('mtg-iss-out').value}\n`;
            copyText(txt);
        }

        function copyElementText(id) {
            copyText(document.getElementById(id).value);
        }

        function copyText(str) {
            const ta = document.createElement('textarea');
            ta.value = str;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            showToast('クリップボードにコピーしました！');
        }

        // Toast Handler
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast-bar');
            const icon = document.getElementById('toast-icon');
            const text = document.getElementById('toast-text');

            text.textContent = message;
            if (type === 'error') {
                icon.className = 'fa-solid fa-circle-exclamation text-red-400';
            } else if (type === 'info') {
                icon.className = 'fa-solid fa-circle-info text-amber-300';
            } else {
                icon.className = 'fa-solid fa-circle-check text-orange';
            }

            toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
            }, 3000);
        }
    </script>
